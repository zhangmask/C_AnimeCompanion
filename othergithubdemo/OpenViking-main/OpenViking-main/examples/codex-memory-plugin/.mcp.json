{
  "mcpServers": {
    "openviking-memory": {
      "url": "__OPENVIKING_MCP_URL__",
      "bearer_token_env_var": "OPENVIKING_API_KEY",
      "env_http_headers": {
        "X-OpenViking-Account": "OPENVIKING_ACCOUNT",
        "X-OpenViking-User": "OPENVIKING_USER",
        "X-OpenViking-Actor-Peer": "OPENVIKING_PEER_ID"
      }
    }
  }
}
